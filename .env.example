APP_NAME=global-hydrology-feed
ENVIRONMENT=dev

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/hydrology

LOG_LEVEL=INFO
NORMALIZATION_VERSION=v1
API_PREFIX=/v1

# Provider enablement
ENABLE_PROVIDER_USGS=true
ENABLE_PROVIDER_EA=true
ENABLE_PROVIDER_GEOGLOWS=true
ENABLE_PROVIDER_WHOS=false

# -------------------
# USGS configuration
# -------------------

USGS_POLL_MINUTES=10
USGS_SITE_LIST=
USGS_DEFAULT_SITE_LIST=01646500
USGS_STATE_CODES=
USGS_BBOX=
USGS_DEFAULT_BBOX=-125,24,-66,50
USGS_PARAMETER_CODES=00060,00065
USGS_HISTORY_LOOKBACK_DAYS=7
USGS_HISTORY_START=
USGS_HISTORY_END=
USGS_TIMEOUT_SECONDS=20
USGS_TRUST_ENV=false
EA_POLL_MINUTES=15


# -------------------
# GEOGLOWS
# -------------------

GEOGLOWS_POLL_MINUTES=30
GEOGLOWS_API_KEY=
GEOGLOWS_API_BASE_URL=https://geoglows.ecmwf.int
GEOGLOWS_REACH_IDS=
GEOGLOWS_REGION=
GEOGLOWS_HISTORY_LOOKBACK_DAYS=7
GEOGLOWS_TIMEOUT_SECONDS=30
GEOGLOWS_TRUST_ENV=true
GEOGLOWS_FORECAST_DATE=
GEOGLOWS_CATALOG_ENDPOINT=/api/AvailableData/
GEOGLOWS_REACH_METADATA_ENDPOINT=/api/GetReachInfo/


# -------------------
# GEOGLOWS forecast bulk (AWS Open Data)
# -------------------
GEOGLOWS_FORECAST_BUCKET=geoglows-v2-forecasts
GEOGLOWS_FORECAST_PREFIX=
GEOGLOWS_METADATA_BUCKET=geoglows-v2
GEOGLOWS_METADATA_TABLES_PREFIX=tables
GEOGLOWS_RETURN_PERIODS_ZARR_PATH=s3://geoglows-v2/retrospective/return-periods.zarr
GEOGLOWS_AWS_REGION=us-west-2

# -------------------
# API behaviour
# -------------------

DEFAULT_LIMIT=100
MAX_LIMIT=1000
