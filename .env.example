APP_NAME=global-hydrology-feed
ENVIRONMENT=dev

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/hydrology

LOG_LEVEL=INFO
NORMALIZATION_VERSION=v1
API_PREFIX=/v1

# Provider enablement
ENABLE_PROVIDER_USGS=true
ENABLE_PROVIDER_EA=true
ENABLE_PROVIDER_GEOGLOWS=true
ENABLE_PROVIDER_WHOS=false

# -------------------
# USGS configuration
# -------------------

USGS_POLL_MINUTES=10

# Disable fallback single-site behavior
USGS_DEFAULT_SITE_LIST=

# Station discovery selectors
USGS_SITE_LIST=
USGS_STATE_CODES=MD
USGS_BBOX=

# Variables
USGS_PARAMETER_CODES=00060,00065

# Historical ingestion
USGS_HISTORY_LOOKBACK_DAYS=7
USGS_HISTORY_START=
USGS_HISTORY_END=

# HTTP behavior
USGS_TIMEOUT_SECONDS=20
USGS_TRUST_ENV=false


# -------------------
# Environment Agency
# -------------------

EA_POLL_MINUTES=15


# -------------------
# GEOGLOWS
# -------------------

GEOGLOWS_POLL_MINUTES=30
GEOGLOWS_API_KEY=


# -------------------
# API behaviour
# -------------------

DEFAULT_LIMIT=100
MAX_LIMIT=1000
